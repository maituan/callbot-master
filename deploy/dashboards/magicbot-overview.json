    {
      "type": "timeseries",
      "title": "Active calls by direction",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "expr": "master_active_calls",
        "legendFormat": "{{direction}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
