      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1.0 }
          ]}
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(master_stage_latency_seconds_bucket{stage=\"tts.first_audio\"}[5m])))",
